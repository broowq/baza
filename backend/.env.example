APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-super-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+psycopg2://lead:lead@localhost:5433/lead
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
SEARXNG_URL=http://localhost:58080
SEARXNG_TIMEOUT_SECONDS=12
SEARXNG_RETRY_COUNT=3
BING_API_KEY=
YANDEX_MAPS_API_KEY=
YANDEX_MAPS_LANG=ru_RU
TWOGIS_API_KEY=
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_APP_URL=http://localhost:3000
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_NAME=baza_refresh_token
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_EXPIRE_MINUTES=1440
PASSWORD_RESET_EXPIRE_MINUTES=30
SCORING_WEIGHTS_JSON={"base":35,"domain":10,"email":20,"phone":10,"address":8,"no_contacts_penalty":-12,"demo_penalty":-20,"aggregator_penalty":-25,"keyword_bonus":12}
SCORING_NICHE_WEIGHTS_JSON={}
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
ANTHROPIC_API_KEY=

# ── LLM provider configuration ────────────────────────────────────────────
# Default: yandex (YandexGPT via Yandex Cloud Foundation Models REST API).
# Other accepted values: gigachat | anthropic. The chat() function still
# cascades through the others on transient failure regardless of primary.
LLM_PROVIDER=yandex

# YandexGPT credentials. Get an Api-Key at:
#   https://console.cloud.yandex.ru/ → IAM → Service accounts → API keys
# The folder ID is part of the modelUri (gpt://<folder>/<model>) — required.
YANDEX_GPT_API_KEY=
YANDEX_GPT_FOLDER_ID=
# Model: yandexgpt-lite/latest | yandexgpt/latest | yandexgpt-32k/latest
YANDEX_GPT_MODEL=yandexgpt-lite/latest
YANDEX_GPT_ENDPOINT=https://llm.api.cloud.yandex.net/foundationModels/v1/completion

# GigaChat (kept as fallback). Get credentials at developers.sber.ru.
# GIGACHAT_API_PERS for personal accounts, GIGACHAT_API_CORP for legal entity.
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat

