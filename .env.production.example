# =============================================================================
# БАЗА — Production Environment Variables
# Copy this file to .env.production and fill in real values.
# =============================================================================

# === Server ===
# Public IP address of your server (used for CORS, frontend API URL, etc.)
SERVER_IP=YOUR_SERVER_IP
APP_ENV=production

# === Security (CHANGE THESE!) ===
# Generate with: openssl rand -hex 32
SECRET_KEY=generate-with-openssl-rand-hex-32
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=generate-strong-password
# Generate with: openssl rand -hex 16
REDIS_PASSWORD=generate-strong-password

# === Database ===
# Connection string is built in docker-compose.prod.yml using POSTGRES_PASSWORD
# No need to set DATABASE_URL here

# === Redis ===
# Connection string is built in docker-compose.prod.yml using REDIS_PASSWORD
# No need to set REDIS_URL here

# === API Keys ===
# 2GIS Maps API key for geocoding
TWOGIS_API_KEY=
# Yandex Maps API key for geocoding
YANDEX_MAPS_API_KEY=
# Anthropic API key for AI features
ANTHROPIC_API_KEY=

# === Auth ===
# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh token lifetime in minutes
REFRESH_TOKEN_EXPIRE_MINUTES=10080
# Set to true when you add HTTPS (domain + SSL)
REFRESH_COOKIE_SECURE=false
# Leave empty for IP-based access; set to your domain later
REFRESH_COOKIE_DOMAIN=

# === CORS ===
# Allowed origins for CORS (comma-separated if multiple)
CORS_ORIGINS=http://${SERVER_IP}

# === Email (optional) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@your-domain.com
# Set to true once email is configured
EMAIL_VERIFICATION_REQUIRED=false

# === Telegram notifications (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Analytics (optional, for frontend) ===
NEXT_PUBLIC_YANDEX_METRIKA_ID=
