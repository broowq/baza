{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 3000
    },
    {
      "name": "backend",
      "runtimeExecutable": "make",
      "runtimeArgs": ["backend"],
      "port": 8000
    },
    {
      "name": "worker",
      "runtimeExecutable": "make",
      "runtimeArgs": ["worker"],
      "port": 0
    },
    {
      "name": "beat",
      "runtimeExecutable": "make",
      "runtimeArgs": ["beat"],
      "port": 0
    }
  ]
}
